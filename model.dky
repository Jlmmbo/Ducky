 0.5 -0.5 -0.5 -0.5 1.0 0.0 0.0
 0.5 0.5 -0.5 -0.5 1.0 1.0 0.0
 -0.5 0.5 -0.5 -0.5 0.0 1.0 0.0

// Face 1: Back of cube 1 (z = 0.5, w = -0.5)
